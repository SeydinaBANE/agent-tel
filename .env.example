# OpenRouter (LLM)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...

# App
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_URL=https://xxxx.ngrok-free.app

# Agent
AGENT_VOICE=fr-FR-DeniseNeural
AGENT_NAME=Assistant
AGENT_LANGUAGE=fr
WHISPER_MODEL=base

# Base de données (SQLite local par défaut, PostgreSQL en prod)
DATABASE_URL=sqlite:///./calls.db

# Notifications Slack / Teams (optionnel)
SLACK_WEBHOOK_URL=

# CRM HTTP (optionnel — HubSpot / Salesforce / Notion)
CRM_API_URL=
CRM_API_KEY=

# Google Calendar (optionnel)
# Coller le JSON du service account sur une seule ligne
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_ID=primary

# Escalade vers humain (optionnel — numéro E.164 du conseiller)
ESCALATION_PHONE=

# STT : langue Whisper ("fr", "en", etc. — vide = détection automatique)
WHISPER_LANGUAGE=fr

# Résumé SMS post-appel (true = envoie un SMS récap à l'appelant en fin d'appel)
SEND_SUMMARY_SMS=false
